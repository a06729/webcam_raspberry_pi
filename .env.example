# api_server 와 같은 MQTT 브로커 주소
MQTT_BROKER=15.168.153.75
MQTT_PORT=1883
# 선택옵션
# MQTT_USERNAME=
# MQTT_PASSWORD=

# 서버 DB(devices 테이블)에 등록된 device_key 와 일치해야 함
DEVICE_KEY=raspi-cam-01

# API 서버 주소 — 시작 시 이 서버에 기기를 자동 등록 (비우면 건너뜀)
API_BASE_URL="api 서버"
DEVICE_NAME=Raspberry Pi Camera
# LATITUDE=37.5665
# LONGITUDE=126.9780

# picam(라즈베리파이 카메라 모듈) | usb(웹캠)
CAMERA_BACKEND=picam
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720

# online 하트비트 간격(초), 0이면 끔
STATUS_INTERVAL=60

# BLE 와이파이 프로비저닝 (와이파이 미연결 시 노트북에서 SSID/비번 수신)
BLE_PROVISION=true
BLE_NAME=raspi-cam-setup
WIFI_INTERFACE=wlan0
# 실행 중 와이파이 끊김 감시 간격(초), 0이면 끔
WIFI_CHECK_INTERVAL=30

# BLE GATT UUID — 노트북 쪽(wifi_manager/.env)과 반드시 동일해야 함
SERVICE_UUID=<SERVICE_UUID 값>
CREDS_CHAR_UUID=<CREDS_CHAR_UUID 값>
STATUS_CHAR_UUID=<STATUS_CHAR_UUID 값>
